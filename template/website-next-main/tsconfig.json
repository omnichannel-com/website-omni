{
  "compilerOptions": {
    // "module": "commonjs",
    "typeRoots": ["./node_modules/@types", "./types"],
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",

    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@blogs/*": ["src/blogs/*"],
      "@/*": [
        "./src/*"
      ],
      "*": ["src/types/*"]
    }
  },
  "include": [
    "src", "src/types",
        "src/**/*",
    "src/blogs/**/*",

    "src/types/typewriter.d.ts",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
, "src/components/landing-sections/testimonial-section.tsx"  ],
  "exclude": [
    "node_modules"
  ]
}