# PostHog analytics
# Get your project token from PostHog project settings
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PostHog API host
# EU region: https://eu.i.posthog.com
# US region: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Contact form submission endpoint
# Set this to your form handler URL (e.g., Formspree, Make/Zapier webhook, or custom API)
# Leave empty to disable form submissions (form will show success UI but not send data)
NEXT_PUBLIC_CONTACT_FORM_ENDPOINT=
